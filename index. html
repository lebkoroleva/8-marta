    openInfo(idx);
  };

  circle.innerHTML =
    '<span class="circle-year">' +
    DATA[i].year +
    "</span>" +
    '<span class="circle-era">' +
    DATA[i].era +
    "</span>" +
    '<span class="circle-hint">смотри подробнее</span>';

  node.appendChild(circle);
  track.appendChild(node);
}

