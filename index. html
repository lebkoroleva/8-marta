var qIndex = 0,
  qScore = 0,
  qAnswered = false;

function startQuiz() {
  qIndex = 0;
  qScore = 0;
  qAnswered = false;
  document.getElementById("quizResult").classList.remove("visible");
  document.getElementById("quizArea").style.display = "block";
  document.getElementById("quizProgress").style.display = "flex";
  buildDots();
  showQuestion();
}

function buildDots() {
  var prog = document.getElementById("quizProgress");
  prog.innerHTML = "";
  for (var i = 0; i < QUIZ.length; i++) {
    var dot = document.createElement("div");
    dot.className = "quiz-dot";
    dot.id = "qdot-" + i;
    if (i === 0) dot.classList.add("active");
    prog.appendChild(dot);
  }
}

function showQuestion() {
  qAnswered = false;
  var q = QUIZ[qIndex],
    letters = ["A", "B", "C", "D"];
  var area = document.getElementById("quizArea");
  var html =
    '<div class="quiz-question-text"><span class="qnum">Вопрос ' +
    (qIndex + 1) +
    "/5:</span><br>" +
    q.q +
    "</div>";
  html += '<div class="quiz-options-list" id="qOpts">';
  for (var i = 0; i < q.opts.length; i++) {
    html +=
      '<div class="quiz-opt" id="qopt-' +
      i +
      '" onclick="pickAnswer(' +
      i +
      ')">' +
      '<span class="opt-letter">' +
      letters[i] +
      "</span><span>" +
      q.opts[i] +
      "</span></div>";
  }
  html += '</div><div class="quiz-explain" id="qExplain">' + q.expl + "</div>";
  html +=
    '<button class="quiz-btn" id="qNextBtn" onclick="nextQ()">' +
    (qIndex < 4 ? "Следующий вопрос &#8594;" : "Показать результат &#8594;") +
    "</button>";
  area.innerHTML = html;
  document.querySelectorAll(".quiz-dot").forEach(function (dot, j) {
    dot.classList.toggle("active", j === qIndex);
  });
}

function pickAnswer(idx) {
  if (qAnswered) return;
  qAnswered = true;
  var q = QUIZ[qIndex];
  document.querySelectorAll(".quiz-opt").forEach(function (opt) {
    opt.classList.add("no-click");
  });
  document.getElementById("qopt-" + q.ans).classList.add("is-correct");
  if (idx !== q.ans) {
    document.getElementById("qopt-" + idx).classList.add("is-wrong");
    var dot = document.getElementById("qdot-" + qIndex);
    if (dot) dot.classList.add("wrong");
  } else {
    qScore++;
    var dot2 = document.getElementById("qdot-" + qIndex);
    if (dot2) dot2.classList.add("correct");
  }
  document.getElementById("qExplain").classList.add("visible");
  document.getElementById("qNextBtn").classList.add("visible");
}

function nextQ() {
  qIndex++;
  if (qIndex >= QUIZ.length) finishQuiz();
  else showQuestion();
}

function finishQuiz() {
  document.getElementById("quizArea").style.display = "none";
  document.getElementById("quizProgress").style.display = "none";
  document.getElementById("resultNum").textContent = qScore;
  var msgs = [
    "Не расстраивайся, теперь ты знаешь больше!",
    "Неплохое начало! Перечитай таймлайн выше.",
    "Средний результат — есть куда расти!",
    "Хорошо! Ты знаешь историю!",
    "Отлично! Почти идеально!",
    "Превосходно! Ты настоящий эксперт!"
  ];
  document.getElementById("resultMsg").textContent = msgs[qScore];
  document.getElementById("quizResult").classList.add("visible");
}

