function openInfo(index) {
  activeIndex = index;
  var d = DATA[index];
  var card = document.getElementById("infoCard");
  var content = document.getElementById("infoCardContent");

  var circles = document.querySelectorAll(".timeline-circle");
  for (var i = 0; i < circles.length; i++) {
    circles[i].classList.toggle("active", i === index);
  }

  content.innerHTML =
    '<div class="info-header">' +
    "<div>" +
    '<div class="info-year">' +
    d.year +
    "</div>" +
    '<span class="info-era">' +
    d.era +
    "</span>" +
    "</div>" +
    "</div>" +
    '<div class="info-title">' +
    d.title +
    "</div>" +
    '<div class="info-desc">' +
    d.desc +
    "</div>" +
    '<div class="info-details"><p>' +
    d.details +
    "</p></div>";

  card.classList.remove("show");
  void card.offsetWidth;
  card.classList.add("show");
  card.scrollIntoView({ behavior: "smooth", block: "nearest" });
}

function closeInfo() {
  document.getElementById("infoCard").classList.remove("show");
  document.querySelectorAll(".timeline-circle").forEach(function (c) {
    c.classList.remove("active");
  });
  activeIndex = -1;
}

