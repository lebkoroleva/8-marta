@import url("https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Inter:wght@400;500;600;700;800&display=swap");

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: "Inter", sans-serif;
  background-color: #bcc4b9;
  min-height: 100vh;
  overflow-x: hidden;
  color: #2c2f1e;
  font-size: 18px;
  position: relative;
}

/* ========== BACKGROUND MIMOSA BRANCHES ========== */
.bg-mimosa {
  position: fixed;
  z-index: 0;
  pointer-events: none;
  opacity: 0.12;
  animation: sway 8s ease-in-out infinite alternate;
}

.bg-mimosa.left {
  bottom: 0;
  left: 5%;
  transform-origin: bottom left;
  animation-delay: 0s;
}

.bg-mimosa.right {
  bottom: 0;
  right: 8%;
  transform-origin: bottom right;
  animation-delay: -4s;
}

@keyframes sway {
  0% {
    transform: rotate(-0.5deg) translateX(0);
  }
  100% {
    transform: rotate(0.8deg) translateX(3px);
  }
}

/* ========== FLOATING POLLEN ========== */
.pollen-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.pollen {
  position: absolute;
  width: 4px;
  height: 4px;
  background: radial-gradient(
    circle,
    #f5d76b 0%,
    #eac403 60%,
    transparent 100%
  );
  border-radius: 50%;
  opacity: 0;
  animation: float-pollen 15s ease-in-out infinite;
  filter: blur(0.5px);
}

