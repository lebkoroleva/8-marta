.hero {
  text-align: center;
  padding: 80px 20px 40px;
  position: relative;
  z-index: 2;
}

.hero h1 {
  font-family: "Caveat", cursive;
  font-size: 4em;
  font-weight: 700;
  color: #3a3f25;
  margin-bottom: 12px;
  text-shadow: 0 2px 15px rgba(245, 215, 107, 0.3);
  animation: fadeInDown 0.8s ease;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero .subtitle {
  font-size: 1.2em;
  color: #5a613b;
  animation: fadeInUp 0.8s ease 0.2s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hand-divider {
  display: block;
  margin: 25px auto;
  width: 180px;
  height: 3px;
  background: linear-gradient(90deg, transparent, #b78002, transparent);
  border-radius: 2px;
  animation: expandWidth 1s ease 0.4s both;
}

@keyframes expandWidth {
  from {
    width: 0;
    opacity: 0;
  }
  to {
    width: 180px;
    opacity: 1;
  }
}

/* ========== EVOLUTION ========== */
.evolution-section {
  max-width: 900px;
  margin: 0 auto 40px;
  padding: 20px;
  position: relative;
  z-index: 2;
  animation: fadeInUp 0.8s ease 0.3s both;
}

.section-title {
  text-align: center;
  font-family: "Caveat", cursive;
  font-size: 2.4em;
  color: #3a3f25;
  margin-bottom: 25px;
}

.evolution-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.45);
  border: 1.5px solid rgba(90, 97, 59, 0.2);
  border-radius: 60px;
  padding: 18px 30px;
  box-shadow: 0 4px 20px rgba(90, 97, 59, 0.08);
}

.evolution-stage {
  text-align: center;
  flex: 1;
  transition: transform 0.3s ease;
}

.evolution-stage:hover {
  transform: translateY(-3px);
}
.evolution-stage:hover .stage-icon {
  transform: scale(1.2) rotate(5deg);
}

.evolution-stage .stage-icon {
  font-size: 2em;
  display: block;
  transition: transform 0.3s ease;
}

.evolution-stage .stage-label {
  font-family: "Caveat", cursive;
  font-size: 1.1em;
  color: #5a613b;
  font-weight: 600;
  margin-top: 5px;
}

.arrow {
  font-size: 1.5em;
  color: #b78002;
  opacity: 0.4;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.1);
  }
}

/* ========== TIMELINE ========== */
.timeline-section {
  position: relative;
  z-index: 2;
  padding: 40px 0 30px;
}

.timeline-scroll-wrapper {
  overflow-x: auto;
  overflow-y: visible;
  padding: 30px 40px 50px;
  scrollbar-width: thin;
  scrollbar-color: #b78002 rgba(202, 209, 201, 0.5);
}

.timeline-scroll-wrapper::-webkit-scrollbar {
  height: 6px;
}
.timeline-scroll-wrapper::-webkit-scrollbar-track {
  background: rgba(202, 209, 201, 0.5);
}
.timeline-scroll-wrapper::-webkit-scrollbar-thumb {
  background: #b78002;
  border-radius: 3px;
}

.timeline-track {
  display: flex;
  align-items: center;
  position: relative;
  min-width: max-content;
  padding: 0 20px;
}

.timeline-track::before {
  content: "";
  position: absolute;
  top: 65px;
  left: 40px;
  height: 3px;
  background: repeating-linear-gradient(
    to right,
    rgba(183, 128, 2, 0.5) 0px,
    rgba(183, 128, 2, 0.5) 12px,
    transparent 12px,
    transparent 22px
  );
  width: 0;
  animation: drawLine 2.5s ease-out forwards 0.5s;
}

@keyframes drawLine {
  to {
    width: calc(100% - 80px);
  }
}

/* ===== CIRCLE NODE ===== */
.timeline-node {
  position: relative;
  z-index: 2;
  margin: 0 20px;
  flex-shrink: 0;
  animation: popIn 0.5s ease both;
}

.timeline-node:nth-child(1) {
  animation-delay: 0.6s;
}
.timeline-node:nth-child(2) {
  animation-delay: 0.7s;
}
.timeline-node:nth-child(3) {
  animation-delay: 0.8s;
}
.timeline-node:nth-child(4) {
  animation-delay: 0.9s;
}
.timeline-node:nth-child(5) {
  animation-delay: 1s;
}
.timeline-node:nth-child(6) {
  animation-delay: 1.1s;
}
.timeline-node:nth-child(7) {
  animation-delay: 1.2s;
}
.timeline-node:nth-child(8) {
  animation-delay: 1.3s;
}
.timeline-node:nth-child(9) {
  animation-delay: 1.4s;
}

@keyframes popIn {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }
  60% {
    transform: scale(1.1);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.timeline-circle {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  border: 3px solid rgba(183, 128, 2, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  box-shadow: 0 4px 15px rgba(90, 97, 59, 0.1);
}

.timeline-circle:hover {
  transform: scale(1.1);
  border-color: #eac403;
  background: rgba(245, 215, 107, 0.3);
  box-shadow: 0 0 25px rgba(234, 196, 3, 0.3);
}

.timeline-circle.active {
  border-color: #eac403;
  background: rgba(245, 215, 107, 0.35);
  box-shadow: 0 0 30px rgba(234, 196, 3, 0.4);
  transform: scale(1.08);
}

.timeline-circle .circle-year {
  font-family: "Caveat", cursive;
  font-size: 1.8em;
  font-weight: 700;
  color: #3a3f25;
  line-height: 1;
}

.timeline-circle .circle-era {
  font-size: 0.5em;
  color: #5a613b;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
  margin-top: 3px;
}

.timeline-circle .circle-hint {
  font-family: "Caveat", cursive;
  font-size: 0.55em;
  color: #b78002;
  margin-top: 4px;
  opacity: 0.7;
  transition: opacity 0.3s;
}

.timeline-circle:hover .circle-hint {
  opacity: 1;
}

.scroll-hint {
  text-align: center;
  color: #5a613b;
  font-size: 0.85em;
  margin-top: 10px;
  opacity: 0.6;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(8px);
  }
}

/* ========== INFO CARD ========== */
.info-card-wrapper {
  max-width: 750px;
  margin: 0 auto;
  padding: 0 20px 40px;
  position: relative;
  z-index: 2;
}

.info-card {
  background: rgba(255, 255, 255, 0.7);
  border: 2px solid rgba(183, 128, 2, 0.3);
  border-radius: 16px;
  padding: 30px;
  box-shadow: 0 8px 30px rgba(90, 97, 59, 0.1);
  display: none;
  animation: fadeSlideIn 0.4s ease;
}

.info-card.show {
  display: block;
}

@keyframes fadeSlideIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.info-card .info-header {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 15px;
}

.info-card .info-year {
  font-family: "Caveat", cursive;
  font-size: 2.8em;
  font-weight: 700;
  color: #3a3f25;
  line-height: 1;
}

.info-card .info-era {
  display: inline-block;
  padding: 3px 12px;
  border: 1.5px solid rgba(90, 97, 59, 0.25);
  border-radius: 4px;
  font-size: 0.7em;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #5a613b;
  background: rgba(245, 215, 107, 0.15);
}

.info-card .info-title {
  font-size: 1.3em;
  font-weight: 700;
  color: #3a3f25;
  margin-bottom: 12px;
  line-height: 1.3;
}

.info-card .info-desc {
  font-size: 1em;
  color: #5a613b;
  line-height: 1.8;
  margin-bottom: 12px;
}

.info-card .info-details {
  padding: 15px 18px;
  background: rgba(245, 215, 107, 0.1);
  border-left: 3px solid #eac403;
  border-radius: 0 8px 8px 0;
}

.info-card .info-details p {
  font-size: 0.95em;
  color: #5a613b;
  line-height: 1.8;
  font-style: italic;
}

.info-card .close-info {
  display: inline-block;
  margin-top: 15px;
  padding: 10px 25px;
  background: #5a613b;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 0.9em;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}

.info-card .close-info:hover {
  background: #b78002;
}

/* ========== FACTS ========== */
.facts-section {
  max-width: 950px;
  margin: 40px auto;
  padding: 20px;
  z-index: 2;
  position: relative;
}

.facts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 20px;
}

.fact-card {
  background: rgba(255, 255, 255, 0.55);
  border: 1.5px solid rgba(90, 97, 59, 0.15);
  border-radius: 12px;
  padding: 25px;
  text-align: center;
  transition: all 0.3s;
  box-shadow: 0 2px 12px rgba(90, 97, 59, 0.06);
  animation: fadeInUp 0.6s ease both;
}

.fact-card:nth-child(1) {
  animation-delay: 0.1s;
}
.fact-card:nth-child(2) {
  animation-delay: 0.2s;
}
.fact-card:nth-child(3) {
  animation-delay: 0.3s;
}
.fact-card:nth-child(4) {
  animation-delay: 0.4s;
}
.fact-card:nth-child(5) {
  animation-delay: 0.5s;
}
.fact-card:nth-child(6) {
  animation-delay: 0.6s;
}

.fact-card:hover {
  transform: translateY(-4px);
  border-color: rgba(234, 196, 3, 0.4);
  box-shadow: 0 8px 25px rgba(90, 97, 59, 0.12);
}

.fact-card .fact-icon {
  font-size: 2.2em;
  margin-bottom: 10px;
  display: block;
  animation: float-icon 3s ease-in-out infinite;
}

.fact-card:nth-child(odd) .fact-icon {
  animation-delay: 0s;
}
.fact-card:nth-child(even) .fact-icon {
  animation-delay: -1.5s;
}

@keyframes float-icon {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-5px);
  }
}

.fact-card .fact-text {
  color: #5a613b;
  line-height: 1.7;
  font-size: 0.95em;
}

.fact-card .fact-text strong {
  color: #3a3f25;
}

/* ========== QUIZ ========== */
.quiz-section {
  max-width: 700px;
  margin: 40px auto;
  padding: 20px;
  z-index: 2;
  position: relative;
}

.quiz-card {
  background: rgba(255, 255, 255, 0.55);
  border: 1.5px solid rgba(90, 97, 59, 0.15);
  border-radius: 16px;
  padding: 30px;
  box-shadow: 0 4px 20px rgba(90, 97, 59, 0.08);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.8s ease 0.2s both;
}

.quiz-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(
    90deg,
    #5a613b,
    #eac403,
    #b78002,
    #eac403,
    #5a613b
  );
  background-size: 300% 100%;
  animation: gradientShift 4s ease infinite;
}

@keyframes gradientShift {
  0%,
  100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

.quiz-subtitle {
  text-align: center;
  color: #5a613b;
  margin-bottom: 25px;
  font-size: 0.95em;
}

.quiz-progress {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-bottom: 25px;
}

.quiz-dot {
  width: 14px;
  height: 14px;
  border: 2px solid rgba(90, 97, 59, 0.25);
  border-radius: 50%;
  background: transparent;
  transition: all 0.3s;
}

.quiz-dot.active {
  background: #eac403;
  border-color: #eac403;
  box-shadow: 0 0 8px rgba(234, 196, 3, 0.4);
  animation: pulse-dot 1s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.15);
  }
}

.quiz-dot.correct {
  background: #5a613b;
  border-color: #5a613b;
}
.quiz-dot.wrong {
  background: #c62828;
  border-color: #c62828;
}

.quiz-question-text {
  font-family: "Caveat", cursive;
  font-size: 1.7em;
  color: #3a3f25;
  margin-bottom: 20px;
  line-height: 1.3;
}

.quiz-question-text .qnum {
  color: #b78002;
  font-weight: 700;
}

.quiz-options-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 15px;
}

.quiz-opt {
  padding: 14px 18px;
  border: 1.5px solid rgba(90, 97, 59, 0.2);
  border-radius: 10px;
  cursor: pointer;
  font-size: 1em;
  transition: all 0.2s;
  background: rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  gap: 12px;
  color: #3a3f25;
}

.quiz-opt .opt-letter {
  width: 30px;
  height: 30px;
  border: 2px solid rgba(90, 97, 59, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.85em;
  flex-shrink: 0;
  transition: all 0.2s;
}

.quiz-opt:hover {
  background: rgba(245, 215, 107, 0.15);
  border-color: rgba(183, 128, 2, 0.3);
  transform: translateX(5px);
}

.quiz-opt.is-correct {
  border-color: #5a613b;
  background: rgba(90, 97, 59, 0.12);
  animation: correctBounce 0.4s ease;
}

@keyframes correctBounce {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.03);
  }
}

.quiz-opt.is-correct .opt-letter {
  background: #5a613b;
  color: #fff;
  border-color: #5a613b;
}

.quiz-opt.is-wrong {
  border-color: #c62828;
  background: rgba(198, 40, 40, 0.06);
  text-decoration: line-through;
  opacity: 0.6;
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%,
  100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-5px);
  }
  75% {
    transform: translateX(5px);
  }
}

.quiz-opt.no-click {
  pointer-events: none;
}

.quiz-explain {
  padding: 12px 15px;
  border-left: 3px solid #eac403;
  background: rgba(245, 215, 107, 0.08);
  border-radius: 0 8px 8px 0;
  font-size: 0.9em;
  color: #5a613b;
  line-height: 1.6;
  margin-bottom: 15px;
  display: none;
  animation: slideInLeft 0.3s ease;
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-10px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.quiz-explain.visible {
  display: block;
}

.quiz-btn {
  display: none;
  padding: 12px 30px;
  background: #5a613b;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1em;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}

.quiz-btn:hover {
  background: #b78002;
  transform: translateY(-2px);
}
.quiz-btn.visible {
  display: inline-block;
  animation: fadeInUp 0.3s ease;
}

.quiz-result {
  text-align: center;
  display: none;
}

.quiz-result.visible {
  display: block;
  animation: fadeInUp 0.5s ease;
}

.result-circle {
  width: 120px;
  height: 120px;
  border: 3px solid #eac403;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 20px auto;
  box-shadow: 0 0 25px rgba(234, 196, 3, 0.2);
  background: rgba(245, 215, 107, 0.1);
  animation: pulse-circle 2s ease-in-out infinite;
}

@keyframes pulse-circle {
  0%,
  100% {
    box-shadow: 0 0 25px rgba(234, 196, 3, 0.2);
  }
  50% {
    box-shadow: 0 0 40px rgba(234, 196, 3, 0.5);
  }
}

.result-num {
  font-family: "Caveat", cursive;
  font-size: 2.8em;
  font-weight: 700;
  color: #3a3f25;
  line-height: 1;
}

.result-of {
  font-size: 0.85em;
  color: #5a613b;
}
.result-msg {
  font-family: "Caveat", cursive;
  font-size: 1.5em;
  color: #b78002;
  margin: 12px 0;
}

.restart-btn {
  padding: 12px 30px;
  background: transparent;
  color: #5a613b;
  border: 2px solid #5a613b;
  border-radius: 10px;
  font-size: 1em;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.restart-btn:hover {
  background: #5a613b;
  color: #fff;
  transform: translateY(-2px);
}

/* ========== FOOTER ========== */
.footer {
  text-align: center;
  padding: 40px 20px;
  color: #5a613b;
  position: relative;
  z-index: 2;
  border-top: 1px solid rgba(90, 97, 59, 0.15);
  max-width: 900px;
  margin: 20px auto 0;
  animation: fadeInUp 0.8s ease 0.4s both;
}

.footer .footer-title {
  font-family: "Caveat", cursive;
  font-size: 2em;
  color: #3a3f25;
  margin-bottom: 8px;
}

.footer .vibe-tag {
  display: inline-block;
  border: 1px solid rgba(90, 97, 59, 0.2);
  padding: 4px 14px;
  border-radius: 20px;
  font-size: 0.7em;
  margin-top: 10px;
  color: #5a613b;
  background: rgba(255, 255, 255, 0.3);
  animation: glow 3s ease-in-out infinite;
}

@keyframes glow {
  0%,
  100% {
    box-shadow: 0 0 5px rgba(234, 196, 3, 0.2);
  }
  50% {
    box-shadow: 0 0 15px rgba(234, 196, 3, 0.4);
  }
}

/* ========== RESPONSIVE ========== */
@media (max-width: 768px) {
  body {
    font-size: 16px;
  }
  .hero h1 {
    font-size: 2.8em;
  }
  .timeline-circle {
    width: 100px;
    height: 100px;
  }
  .timeline-circle .circle-year {
    font-size: 1.4em;
  }
  .timeline-node {
    margin: 0 12px;
  }
  .evolution-bar {
    flex-direction: column;
    gap: 10px;
    padding: 18px;
    border-radius: 20px;
  }
  .arrow {
    transform: rotate(90deg);
  }
  .corner-flower.left svg,
  .corner-flower.right svg {
    width: 140px;
    height: auto;
  }
  .bg-mimosa.left,
  .bg-mimosa.right {
    opacity: 0.08;
  }
  .bg-mimosa.left svg,
  .bg-mimosa.right svg {
    width: 180px;
  }
  .falling-flower {
    font-size: 14px !important;
  }
}
